-    for (int i = 0; i < 4; i++) {
-      for (int j = jstart; j < jend; j++) {
-        Options options = CurrentOptions();
-        const size_t row_count = RecoveryTestHelper::FillData(this, options);
-        RecoveryTestHelper::CorruptWAL(this, options, i * .3,
