-      return ToNumber(a) - ToNumber(b);
-    }
-    virtual void FindShortestSeparator(std::string* s,
-                                       const Slice& l) const override {
-      ToNumber(*s);
-      ToNumber(l);
-    }
-    virtual void FindShortSuccessor(std::string* key) const override {
-      ToNumber(*key);
-    }
-   private:
